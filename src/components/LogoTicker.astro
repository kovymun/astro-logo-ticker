---
/**
 * Infinite auto-scrolling logo carousel with edge fade masks.
 * Pure Astro + Vanilla CSS: no framework dependencies.
 */

import type { Props } from "../types/types";
import { def_logos } from "../data/logo";

const speedMap: Record<NonNullable<Props["speed"]>, string> = {
  slow: "60s",
  medium: "35s",
  fast: "18s",
};

const {
  logos = def_logos,
  speed = "medium",
  direction = "left",
  pauseOnHover = true,
  label = "Trusted by teams at",
} = Astro.props;

const duration = speedMap[speed];
// animation direction
const animDirection = direction === "right" ? "reverse" : "normal";
// Duplicate for seamless infinite loop
const doubled = [...logos, ...logos];
---

<section class="ticker-section" aria-label={label}>
  {label && <p class="ticker-label">{label}</p>}

  <div class={`ticker-wrapper${pauseOnHover ? " pause-on-hover" : ""}`}>
    <div class="ticker-mask ticker-mask--left" aria-hidden="true"></div>

    <div class="ticker-viewport">
      <ul
        class="ticker-track"
        aria-hidden="true"
        style={`animation-duration: ${duration}; animation-direction: ${animDirection};`}
      >
        {
          doubled.map((logo) => (
            <li class="ticker-item">
              <Fragment set:html={logo.svg} />
            </li>
          ))
        }
      </ul>
    </div>

    <div class="ticker-mask ticker-mask--right" aria-hidden="true"></div>
  </div>

  <!-- Accessible brand list for screen readers -->
  <ul class="sr-only">
    {logos.map((logo) => <li>{logo.name}</li>)}
  </ul>
</section>

<style>
  .ticker-section {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 2.5rem 0;
  }

  .ticker-label {
    font-family: var(--font-mono, "DM Mono", monospace);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ticker-label-color, rgba(255 255 255 / 0.35));
    margin: 0;
  }

  .ticker-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ticker-mask {
    position: absolute;
    top: 0;
    bottom: 0;
    width: clamp(60px, 10vw, 140px);
    z-index: 2;
    pointer-events: none;
  }

  .ticker-mask--left {
    left: 0;
    background: linear-gradient(
      to right,
      var(--ticker-bg, #080808) 0%,
      transparent 100%
    );
  }

  .ticker-mask--right {
    right: 0;
    background: linear-gradient(
      to left,
      var(--ticker-bg, #080808) 0%,
      transparent 100%
    );
  }

  .ticker-viewport {
    overflow: hidden;
    width: 100%;
  }

  .ticker-track {
    display: flex;
    align-items: center;
    /* max-content lets the flex row expand beyond the viewport */
    width: max-content;
    list-style: none;
    margin: 0;
    padding: 0.25rem 0;
    animation-name: ticker-scroll;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    will-change: transform;
  }

  /* Pause on hover: applied only when wrapper has the class */
  .pause-on-hover:hover .ticker-track {
    animation-play-state: paused;
  }

  .ticker-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 clamp(1.25rem, 3vw, 2.5rem);
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 0.2s ease;
  }

  .ticker-item:hover {
    opacity: 1;
  }

  .ticker-item :global(svg) {
    height: 22px;
    width: auto;
    display: block;
    color: var(--ticker-logo-color, #ffffff);
    flex-shrink: 0;
  }

  /* Keyframes: animations*/
  @keyframes ticker-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
    }
    .ticker-item {
      opacity: 0.65;
    }
  }

  /* Screen Reader Utils*/
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
